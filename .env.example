# Airflow (local Docker) — copy to `.env` and adjust.
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__API_AUTH__JWT_SECRET=change_me_in_prod
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Snowflake (also create Airflow UI Connection `snowflake_default`)
SNOWFLAKE_ACCOUNT=xy12345.us-west-2
SNOWFLAKE_USER=AIRFLOW_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_DATABASE=EMPLOYEES_ETL
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA_RAW=RAW

# Path inside the worker container (compose mounts ./data/incoming here)
EMPLOYEES_LOCAL_PATH=/opt/airflow/data/incoming/employees.csv
